---
import { reader } from '../lib/keystatic-reader';

const statsData = await reader.singletons.stats.read();
const stats = statsData?.items ?? [];
---

<section class="border-y border-zinc-800/50 py-16" data-reveal>
  <div class="mx-auto grid max-w-7xl grid-cols-2 gap-8 px-6 md:grid-cols-4 md:gap-0">
    {
      stats.map((stat, i) => (
        <div
          class:list={[
            'flex flex-col items-center gap-2 text-center',
            i < stats.length - 1 && 'md:border-r md:border-zinc-800',
          ]}
        >
          <span
            class="text-3xl font-bold text-amber-500 md:text-4xl"
            data-counter-target={String(stat.value)}
            data-counter-suffix={stat.suffix}
          >
            0{stat.suffix}
          </span>
          <span class="text-xs font-medium uppercase tracking-widest text-zinc-500">
            {stat.label}
          </span>
        </div>
      ))
    }
  </div>
</section>
