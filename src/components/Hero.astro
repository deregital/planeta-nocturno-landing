---
import { Image } from 'astro:assets';
import adminView from '../assets/screenshots/todos-eventos-admin.png';
import ticketView from '../assets/screenshots/entrada.jpg';
---

<section class="relative min-h-[100dvh] px-6 pt-24 lg:pt-0">
  <!-- Animated mesh gradient background -->
  <div class="pointer-events-none absolute inset-0 -z-10 overflow-hidden">
    <div class="mesh-blob mesh-blob-1"></div>
    <div class="mesh-blob mesh-blob-2"></div>
    <div class="mesh-blob mesh-blob-3"></div>
  </div>

  <div
    class="mx-auto grid max-w-7xl grid-cols-1 items-center gap-12 lg:min-h-[100dvh] lg:grid-cols-[1.4fr_1fr] lg:gap-16"
  >
    <!-- Left: Copy -->
    <div class="flex flex-col items-start gap-6 py-12 lg:py-0">
      <span
        class="inline-flex items-center rounded-full border border-amber-500/20 bg-amber-500/10 px-4 py-1.5 text-sm font-medium text-amber-500"
        data-reveal
      >
        Plataforma de ticketing para boliches
      </span>

      <h1
        class="text-4xl font-bold leading-none tracking-tighter md:text-6xl"
        data-reveal
        data-reveal-delay="100"
      >
        Tu boliche.<br />
        Tu marca.<br />
        <span class="text-amber-500">Tu sistema de entradas.</span>
      </h1>

      <p
        class="max-w-[50ch] text-lg leading-relaxed text-zinc-400"
        data-reveal
        data-reveal-delay="200"
      >
        Gestioná eventos, vendé entradas con cualquier medio de pago, controlá el ingreso con QR
        y conocé a tu público. Todo desde una plataforma con tu propia marca.
      </p>

      <div class="flex flex-wrap items-center gap-4" data-reveal data-reveal-delay="300">
        <a
          href="#contacto"
          data-magnetic="0.3"
          class="inline-flex items-center rounded-full bg-amber-500 px-7 py-3 text-base font-semibold text-zinc-950 transition-colors duration-200 hover:bg-amber-400 active:scale-[0.98]"
        >
          Quiero una demo
        </a>
        <a
          href="#funcionalidades"
          class="inline-flex items-center rounded-full border border-zinc-700 px-7 py-3 text-base font-medium text-zinc-300 transition-colors duration-200 hover:border-zinc-500 hover:text-zinc-100"
        >
          Ver funcionalidades
        </a>
      </div>
    </div>

    <!-- Right: Screenshots composite with parallax -->
    <div class="relative hidden lg:block" data-reveal data-reveal-delay="200">
      <!-- Main screenshot -->
      <div
        class="overflow-hidden rounded-2xl border border-zinc-800 bg-zinc-900 p-1.5 shadow-[0_20px_60px_-15px_rgba(245,158,11,0.15)] will-change-transform"
        data-parallax="0.08"
        data-parallax-rotate="2"
      >
        <!-- Browser chrome -->
        <div class="flex items-center gap-1.5 rounded-t-xl bg-zinc-800 px-3 py-2">
          <div class="h-2.5 w-2.5 rounded-full bg-zinc-600"></div>
          <div class="h-2.5 w-2.5 rounded-full bg-zinc-600"></div>
          <div class="h-2.5 w-2.5 rounded-full bg-zinc-600"></div>
        </div>
        <Image
          src={adminView}
          alt="Panel de gestión de eventos de Planeta Nocturno"
          class="w-full rounded-b-xl"
          widths={[400, 800]}
          sizes="(max-width: 1024px) 100vw, 40vw"
        />
      </div>

      <!-- Floating ticket screenshot — faster parallax for depth -->
      <div
        class="absolute -bottom-8 -left-12 w-44 overflow-hidden rounded-2xl border border-zinc-800 bg-zinc-900 p-1 shadow-[0_12px_40px_-10px_rgba(245,158,11,0.2)] will-change-transform"
        data-parallax="0.18"
        data-parallax-rotate="-3"
        style="animation: float 6s ease-in-out infinite;"
      >
        <Image
          src={ticketView}
          alt="Entrada digital con código QR"
          class="w-full rounded-xl"
          widths={[200, 400]}
          sizes="176px"
        />
      </div>
    </div>

    <!-- Mobile: single screenshot -->
    <div class="relative lg:hidden" data-reveal>
      <div
        class="overflow-hidden rounded-2xl border border-zinc-800 bg-zinc-900 p-1.5 shadow-[0_20px_60px_-15px_rgba(245,158,11,0.15)]"
      >
        <div class="flex items-center gap-1.5 rounded-t-xl bg-zinc-800 px-3 py-2">
          <div class="h-2.5 w-2.5 rounded-full bg-zinc-600"></div>
          <div class="h-2.5 w-2.5 rounded-full bg-zinc-600"></div>
          <div class="h-2.5 w-2.5 rounded-full bg-zinc-600"></div>
        </div>
        <Image
          src={adminView}
          alt="Panel de gestión de eventos"
          class="w-full rounded-b-xl"
          widths={[400, 800]}
          sizes="100vw"
        />
      </div>
    </div>
  </div>
</section>

<style>
  .mesh-blob {
    position: absolute;
    border-radius: 50%;
    filter: blur(100px);
    opacity: 0.07;
    transition: opacity 0.8s ease;
  }

  .mesh-blob-1 {
    width: 600px;
    height: 600px;
    background: radial-gradient(circle, #f59e0b, transparent 70%);
    top: -10%;
    right: -5%;
    animation: mesh-drift-1 18s ease-in-out infinite;
  }

  .mesh-blob-2 {
    width: 500px;
    height: 500px;
    background: radial-gradient(circle, #d97706, transparent 70%);
    bottom: 10%;
    left: -10%;
    animation: mesh-drift-2 22s ease-in-out infinite;
  }

  .mesh-blob-3 {
    width: 400px;
    height: 400px;
    background: radial-gradient(circle, #92400e, transparent 70%);
    top: 40%;
    left: 40%;
    animation: mesh-drift-3 26s ease-in-out infinite;
  }

  @keyframes mesh-drift-1 {
    0%, 100% { transform: translate(0, 0) scale(1); }
    33% { transform: translate(-60px, 40px) scale(1.1); }
    66% { transform: translate(30px, -20px) scale(0.95); }
  }

  @keyframes mesh-drift-2 {
    0%, 100% { transform: translate(0, 0) scale(1); }
    33% { transform: translate(50px, -30px) scale(1.05); }
    66% { transform: translate(-40px, 50px) scale(1.1); }
  }

  @keyframes mesh-drift-3 {
    0%, 100% { transform: translate(0, 0) scale(1); }
    33% { transform: translate(40px, 30px) scale(1.15); }
    66% { transform: translate(-30px, -40px) scale(0.9); }
  }

  @media (prefers-reduced-motion: reduce) {
    .mesh-blob { animation: none; }
  }
</style>
