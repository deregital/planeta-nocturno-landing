---
import { reader } from '../lib/keystatic-reader';

const footer = await reader.singletons.footer.read();
const nav = await reader.singletons.nav.read();
const links = nav?.links ?? [];
const year = new Date().getFullYear();
---

<footer class="border-t border-zinc-800/50">
  <div class="mx-auto grid max-w-7xl grid-cols-1 gap-10 px-6 py-12 md:grid-cols-[2fr_1fr] md:gap-8">
    <!-- Brand -->
    <div>
      <a href="#" class="text-lg font-bold tracking-tight">
        <span class="text-zinc-100">{footer?.logoPartA}</span><span class="text-amber-500">{footer?.logoPartB}</span>
      </a>
      <p class="mt-3 max-w-[35ch] text-sm leading-relaxed text-zinc-500">
        {footer?.brandDescription}
      </p>
    </div>

    <!-- Links -->
    <div>
      <h5 class="text-xs font-semibold uppercase tracking-widest text-zinc-400">Navegación</h5>
      <ul class="mt-4 flex flex-col gap-2.5">
        {links.map((link) => (
          <li>
            <a href={link.href} class="text-sm text-zinc-500 transition-colors hover:text-zinc-300">
              {link.label}
            </a>
          </li>
        ))}
      </ul>
    </div>
  </div>

  <!-- Bottom bar -->
  <div class="border-t border-zinc-800/50 px-6 py-5">
    <p class="mx-auto max-w-7xl text-center text-xs text-zinc-600">
      &copy; {year} {footer?.copyrightName}. Todos los derechos reservados.
    </p>
  </div>
</footer>
