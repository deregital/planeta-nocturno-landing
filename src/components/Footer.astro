---
const year = new Date().getFullYear();
---

<footer class="border-t border-zinc-800/50">
  <div class="mx-auto grid max-w-7xl grid-cols-1 gap-10 px-6 py-12 md:grid-cols-[2fr_1fr_1fr] md:gap-8">
    <!-- Brand -->
    <div>
      <a href="#" class="text-lg font-bold tracking-tight">
        <span class="text-zinc-100">Planeta</span><span class="text-amber-500">Nocturno</span>
      </a>
      <p class="mt-3 max-w-[35ch] text-sm leading-relaxed text-zinc-500">
        Plataforma de ticketing para boliches argentinos.
      </p>
    </div>

    <!-- Links -->
    <div>
      <h5 class="text-xs font-semibold uppercase tracking-widest text-zinc-400">Navegación</h5>
      <ul class="mt-4 flex flex-col gap-2.5">
        <li>
          <a href="#funcionalidades" class="text-sm text-zinc-500 transition-colors hover:text-zinc-300">
            Funcionalidades
          </a>
        </li>
        <li>
          <a href="#organizadores" class="text-sm text-zinc-500 transition-colors hover:text-zinc-300">
            Organizadores
          </a>
        </li>
        <li>
          <a href="#como-funciona" class="text-sm text-zinc-500 transition-colors hover:text-zinc-300">
            Cómo funciona
          </a>
        </li>
        <li>
          <a href="#contacto" class="text-sm text-zinc-500 transition-colors hover:text-zinc-300">
            Contacto
          </a>
        </li>
      </ul>
    </div>

    <!-- Contact -->
    <div>
      <h5 class="text-xs font-semibold uppercase tracking-widest text-zinc-400">Contacto</h5>
      <ul class="mt-4 flex flex-col gap-2.5">
        <li>
          <a
            href="https://wa.me/5491128364834"
            target="_blank"
            rel="noopener noreferrer"
            class="text-sm text-zinc-500 transition-colors hover:text-zinc-300"
          >
            +54 9 11 2836-4834
          </a>
        </li>
        <li>
          <a
            href="mailto:info@deregital.com"
            class="text-sm text-zinc-500 transition-colors hover:text-zinc-300"
          >
            info@deregital.com
          </a>
        </li>
      </ul>
    </div>
  </div>

  <!-- Bottom bar -->
  <div class="border-t border-zinc-800/50 px-6 py-5">
    <p class="mx-auto max-w-7xl text-center text-xs text-zinc-600">
      &copy; {year} Planeta Nocturno. Todos los derechos reservados.
    </p>
  </div>
</footer>
