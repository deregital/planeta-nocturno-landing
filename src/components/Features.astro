---
import FeatureRow from './FeatureRow.astro';
import eventoCliente from '../assets/screenshots/evento-como-cliente.png';
import todosEventos from '../assets/screenshots/todos-eventos-admin.png';
import baseDeDatos from '../assets/screenshots/base-de-datos.jpg';
import entrada from '../assets/screenshots/entrada.jpg';
import { reader } from '../lib/keystatic-reader';

const features = await reader.singletons.features.read();
const images = [eventoCliente, todosEventos, baseDeDatos, entrada];
---

<section id="funcionalidades" class="py-16 lg:py-24">
  <div class="mx-auto max-w-7xl px-6" data-reveal>
    <span class="text-sm font-medium uppercase tracking-widest text-amber-500">
      {features?.sectionLabel}
    </span>
  </div>

  {features?.items.map((item, i) => (
    <FeatureRow
      title={item.title}
      description={item.description}
      bullets={item.bullets}
      image={images[i]}
      imageAlt={item.imageAlt}
      reversed={item.reversed}
      phoneFrame={item.phoneFrame}
    />
  ))}
</section>
