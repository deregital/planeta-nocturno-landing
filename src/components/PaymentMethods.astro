---
import { reader } from '../lib/keystatic-reader';

const pm = await reader.singletons.paymentMethods.read();
const methods = pm?.methods ?? [];
---

<section class="border-y border-zinc-800/30 py-20 lg:py-28">
  <div class="mx-auto max-w-7xl px-6">
    <div class="grid grid-cols-1 gap-12 lg:grid-cols-[1fr_1.2fr] lg:gap-20">
      <!-- Left: copy -->
      <div data-reveal>
        <span class="text-sm font-medium uppercase tracking-widest text-amber-500">
          {pm?.sectionLabel}
        </span>
        <h2 class="mt-4 text-3xl font-bold leading-tight tracking-tight md:text-4xl">
          {pm?.heading}<br />
          <span class="text-zinc-400">{pm?.headingAccent}</span>
        </h2>
        <p class="mt-5 max-w-[45ch] leading-relaxed text-zinc-400">
          {pm?.description}
        </p>
        <div class="mt-6 flex items-center gap-3">
          <div class="flex h-10 items-center rounded-lg border border-zinc-800 bg-zinc-900 px-4">
            <span class="text-sm font-semibold text-zinc-300">Mercado Pago</span>
          </div>
          <div class="flex h-10 items-center rounded-lg border border-zinc-800 bg-zinc-900 px-4">
            <span class="text-sm font-semibold text-zinc-300">Efectivo</span>
          </div>
        </div>
      </div>

      <!-- Right: methods grid -->
      <div class="grid grid-cols-1 gap-4 sm:grid-cols-2">
        {
          methods.map((method, i) => (
            <div
              class="rounded-xl border border-zinc-800/60 bg-zinc-900/30 px-5 py-4"
              data-reveal
              data-reveal-delay={String(i * 80)}
            >
              <h4 class="text-sm font-semibold text-zinc-100">{method.name}</h4>
              <p class="mt-1 text-xs leading-relaxed text-zinc-500">{method.description}</p>
            </div>
          ))
        }
      </div>
    </div>
  </div>
</section>
